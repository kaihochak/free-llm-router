---
import Layout from '../../layouts/base.astro';
import DataAttributionFooter from '../../components/DataAttributionFooter.astro';
import { createDb } from '@/db';
import {
  getModelsByProvider,
  getModelFeedbackById,
  getProviderAvailability,
  getDistinctProviders,
} from '@/services/openrouter';
import { AvailabilityMatrix } from '@/components/model-availability/AvailabilityMatrix';
import { generateProviderSchema, generateBreadcrumbSchema } from '@/lib/seo';
import { modelDetailPath, providerDetailPath } from '@/lib/model-urls';
import { ProviderHealthChart } from '@/components/model-health/ProviderHealthChart';

const { provider } = Astro.params;
if (!provider) {
  return Astro.redirect('/models');
}

const runtime = (Astro.locals as { runtime?: { env?: Record<string, string> } }).runtime;
const databaseUrl = runtime?.env?.DATABASE_URL || import.meta.env.DATABASE_URL;
const db = createDb(databaseUrl);

const models = await getModelsByProvider(db, provider);
if (models.length === 0) {
  return new Response(null, { status: 404, statusText: 'Provider not found' });
}

const providerCapitalized = provider.charAt(0).toUpperCase() + provider.slice(1);

// Fetch feedback for each model (1h, 6h, 24h, 7d, 30d) + availability + other providers
const HOUR_MS = 60 * 60 * 1000;
const modelIds = models.map((m) => m.id);

const [feedbackResults, availabilityData, allProviders] = await Promise.all([
  Promise.all(
    modelIds.map(async (id) => {
      const [f1h, f6h, f24h, f7d, f30d] = await Promise.all([
        getModelFeedbackById(db, id, 1 * HOUR_MS),
        getModelFeedbackById(db, id, 6 * HOUR_MS),
        getModelFeedbackById(db, id, 24 * HOUR_MS),
        getModelFeedbackById(db, id, 7 * 24 * HOUR_MS),
        getModelFeedbackById(db, id, 30 * 24 * HOUR_MS),
      ]);
      return { id, f1h, f6h, f24h, f7d, f30d };
    })
  ),
  getProviderAvailability(db, provider, 90),
  getDistinctProviders(db),
]);

// Build feedback lookup
const feedbackMap = new Map(feedbackResults.map((f) => [f.id, f]));
const hasFeedback = feedbackResults.some((f) => f.f1h || f.f6h || f.f24h || f.f7d || f.f30d);

// Other providers (exclude current)
const otherProviders = allProviders.filter((p) => p !== provider);

// SEO
const title = `Free ${providerCapitalized} Models on OpenRouter`;
const description = `Browse ${models.length} free ${providerCapitalized} AI models available on OpenRouter. View reliability, error rates, and availability data.`;

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Providers', url: '/providers' },
  { name: providerCapitalized, url: providerDetailPath(provider) },
];

const jsonLd = [
  generateProviderSchema(provider, models.length),
  generateBreadcrumbSchema(breadcrumbItems),
];

function formatTokens(count: number | null): string {
  if (!count) return '-';
  if (count >= 1_000_000) return `${(count / 1_000_000).toFixed(1)}M`;
  if (count >= 1_000) return `${(count / 1_000).toFixed(0)}K`;
  return count.toString();
}

function errorRateColor(rate: number | undefined): string {
  if (rate === undefined) return 'text-muted-foreground';
  if (rate > 20) return 'text-destructive';
  if (rate > 10) return 'text-yellow-600 dark:text-yellow-400';
  return 'text-green-600 dark:text-green-400';
}
---

<Layout title={title} description={description} jsonLd={jsonLd} url={providerDetailPath(provider)}>
  <div class="container mx-auto max-w-3xl px-4 py-8">
    <!-- Breadcrumbs -->
    <nav class="mb-6 text-sm text-muted-foreground" aria-label="Breadcrumb">
      <ol class="flex items-center gap-1.5">
        <li><a href="/" class="hover:text-foreground transition-colors">Home</a></li>
        <li class="text-muted-foreground/50">/</li>
        <li><a href="/providers" class="hover:text-foreground transition-colors">Providers</a></li>
        <li class="text-muted-foreground/50">/</li>
        <li class="text-foreground font-medium truncate">{providerCapitalized}</li>
      </ol>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-start justify-between gap-4">
        <div class="flex items-start gap-4 min-w-0">
          <img
            src={`https://models.dev/logos/${provider}.svg`}
            alt={provider}
            class="h-10 w-10 object-contain opacity-70 dark:invert dark:opacity-80 mt-1 shrink-0"
            onerror="this.style.display='none'"
          />
          <div class="min-w-0">
            <h1 class="text-2xl font-bold tracking-tight text-foreground">
              {providerCapitalized}
            </h1>
            <p class="text-sm text-muted-foreground mt-1">
              {models.length} free model{models.length !== 1 ? 's' : ''} on OpenRouter
            </p>
          </div>
        </div>
        <a
          href={`https://openrouter.ai/${provider}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border px-3 py-1.5 text-sm font-medium text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors shrink-0 mt-1"
        >
          OpenRouter
          <svg
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M7 17L17 7"></path><path d="M7 7h10v10"></path>
          </svg>
        </a>
      </div>
    </header>

    <!-- Models List -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold mb-3">Free Models</h2>
      <div class="rounded-xl border bg-card divide-y overflow-hidden">
        {
          models.map((model) => {
            const isNew = model.createdAt
              ? new Date(model.createdAt) > new Date(Date.now() - 7 * 24 * 60 * 60 * 1000)
              : false;
            const badges: string[] = [];
            if (model.inputModalities?.includes('image')) badges.push('Vision');
            if (model.supportedParameters?.includes('tools')) badges.push('Tools');
            if (
              model.supportedParameters?.includes('reasoning') ||
              model.supportedParameters?.includes('include_reasoning')
            )
              badges.push('Reasoning');
            if ((model.contextLength ?? 0) >= 100000) badges.push('Long Context');

            return (
              <a
                href={modelDetailPath(model.id)}
                class="group flex items-center gap-3 px-4 py-3 transition-colors hover:bg-muted/50"
              >
                <div class="flex min-w-0 flex-1 items-center gap-2">
                  <span class="font-medium text-foreground group-hover:text-primary transition-colors truncate">
                    {model.name}
                  </span>
                  {isNew && (
                    <span class="inline-flex items-center rounded-full bg-blue-500/15 px-2 py-0.5 text-[10px] font-medium text-blue-600 dark:text-blue-400">
                      New
                    </span>
                  )}
                  {badges.length > 0 && (
                    <div class="hidden sm:flex gap-1">
                      {badges.map((badge) => (
                        <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium text-muted-foreground">
                          {badge}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
                <div class="flex shrink-0 items-center gap-3 text-xs text-muted-foreground">
                  {(model.contextLength || model.maxCompletionTokens) && (
                    <span class="font-mono hidden sm:inline">
                      {formatTokens(model.contextLength)} /{' '}
                      {formatTokens(model.maxCompletionTokens)}
                    </span>
                  )}
                  <svg
                    class="h-3.5 w-3.5 text-muted-foreground group-hover:text-primary transition-colors"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                </div>
              </a>
            );
          })
        }
      </div>
    </section>

    <!-- Reliability -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold mb-3">Error Rate</h2>
      <p class="text-xs text-muted-foreground mb-3 leading-relaxed">
        Based on feedback reported by Free LLM Router users. Error rate reflects the percentage of
        requests that encountered issues such as rate limiting, unavailability, or errors.
        <a href="/docs" class="underline hover:text-foreground transition-colors">Learn more</a>.
      </p>

      <!-- Interactive chart (all models in one chart) -->
      <div class="mb-4">
        <ProviderHealthChart client:load provider={provider} />
      </div>

      <!-- Static error rates table (SEO-friendly) -->
      {
        hasFeedback && (
          <div class="rounded-xl border bg-card overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b">
                    <th class="px-4 py-3 text-left font-medium text-muted-foreground">Model</th>
                    <th class="px-4 py-3 text-right font-medium text-muted-foreground">1h</th>
                    <th class="px-4 py-3 text-right font-medium text-muted-foreground">6h</th>
                    <th class="px-4 py-3 text-right font-medium text-muted-foreground">24h</th>
                    <th class="px-4 py-3 text-right font-medium text-muted-foreground">7d</th>
                    <th class="px-4 py-3 text-right font-medium text-muted-foreground">30d</th>
                  </tr>
                </thead>
                <tbody class="divide-y">
                  {models.map((model) => {
                    const fb = feedbackMap.get(model.id);
                    if (!fb || (!fb.f1h && !fb.f6h && !fb.f24h && !fb.f7d && !fb.f30d)) return null;
                    return (
                      <tr>
                        <td class="px-4 py-3 font-medium text-foreground truncate max-w-[200px]">
                          <a
                            href={modelDetailPath(model.id)}
                            class="hover:text-primary transition-colors"
                          >
                            {model.name}
                          </a>
                        </td>
                        <td
                          class:list={[
                            'px-4 py-3 text-right font-mono',
                            errorRateColor(fb.f1h?.errorRate),
                          ]}
                        >
                          {fb.f1h ? `${fb.f1h.errorRate.toFixed(1)}%` : '-'}
                        </td>
                        <td
                          class:list={[
                            'px-4 py-3 text-right font-mono',
                            errorRateColor(fb.f6h?.errorRate),
                          ]}
                        >
                          {fb.f6h ? `${fb.f6h.errorRate.toFixed(1)}%` : '-'}
                        </td>
                        <td
                          class:list={[
                            'px-4 py-3 text-right font-mono',
                            errorRateColor(fb.f24h?.errorRate),
                          ]}
                        >
                          {fb.f24h ? `${fb.f24h.errorRate.toFixed(1)}%` : '-'}
                        </td>
                        <td
                          class:list={[
                            'px-4 py-3 text-right font-mono',
                            errorRateColor(fb.f7d?.errorRate),
                          ]}
                        >
                          {fb.f7d ? `${fb.f7d.errorRate.toFixed(1)}%` : '-'}
                        </td>
                        <td
                          class:list={[
                            'px-4 py-3 text-right font-mono',
                            errorRateColor(fb.f30d?.errorRate),
                          ]}
                        >
                          {fb.f30d ? `${fb.f30d.errorRate.toFixed(1)}%` : '-'}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </div>
        )
      }
    </section>

    <!-- Availability -->
    {
      availabilityData.models.length > 0 && (
        <section class="mb-8">
          <h2 class="text-lg font-semibold mb-3">Availability</h2>
          <p class="text-xs text-muted-foreground mb-3">
            Daily snapshots showing whether each {providerCapitalized} model was accessible as a
            free model on OpenRouter.
          </p>
          <AvailabilityMatrix
            client:load
            models={availabilityData.models}
            dates={availabilityData.dates}
          />
        </section>
      )
    }

    <!-- More Providers -->
    {
      otherProviders.length > 0 && (
        <section class="mb-8">
          <h2 class="text-lg font-semibold mb-3">More Providers</h2>
          <div class="rounded-xl border bg-card divide-y overflow-hidden">
            {otherProviders.slice(0, 10).map((p) => {
              const pCapitalized = p.charAt(0).toUpperCase() + p.slice(1);
              return (
                <a
                  href={providerDetailPath(p)}
                  class="group flex items-center gap-3 px-4 py-3 transition-colors hover:bg-muted/50"
                >
                  <img
                    src={`https://models.dev/logos/${p}.svg`}
                    alt={p}
                    class="h-5 w-5 object-contain opacity-70 dark:invert dark:opacity-80 shrink-0"
                    onerror="this.style.display='none'"
                  />
                  <span class="font-medium text-foreground group-hover:text-primary transition-colors truncate capitalize">
                    {pCapitalized}
                  </span>
                  <svg
                    class="ml-auto h-3.5 w-3.5 shrink-0 text-muted-foreground group-hover:text-primary transition-colors"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                </a>
              );
            })}
          </div>
        </section>
      )
    }

    <DataAttributionFooter class="pt-8" />
  </div>
</Layout>
